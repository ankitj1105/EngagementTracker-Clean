@{
    ViewData["Title"] = "Live Quiz";
    var role = ViewBag.Role ?? "student";
    var name = ViewBag.Name ?? "User";
    var uid  = ViewBag.Uid  ?? "";
}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1"/>
<title>Live Quiz</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
<style>
*{margin:0;padding:0;box-sizing:border-box;}
:root{--bg:#07070e;--surface:#0f0f18;--surface2:#13131e;--border:rgba(255,255,255,.06);--purple:#7c3aed;--purple2:#4f46e5;--text:#f0eeff;--muted:rgba(255,255,255,.4);}
body{background:var(--bg);font-family:'Segoe UI',system-ui,sans-serif;color:var(--text);min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:20px;}
.quiz-container{width:100%;max-width:700px;position:relative;z-index:2;}
.header{text-align:center;margin-bottom:32px;}
.header h1{font-size:1.8rem;font-weight:800;background:linear-gradient(135deg,#a78bfa,#7c3aed);-webkit-background-clip:text;-webkit-text-fill-color:transparent;}
.header p{color:var(--muted);margin-top:6px;font-size:.85rem;}
.card{background:var(--surface);border:1px solid var(--border);border-radius:16px;padding:28px;}
.question-text{font-size:1.2rem;font-weight:700;color:var(--text);margin-bottom:24px;line-height:1.5;}
.options{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.option-btn{padding:16px 20px;background:var(--surface2);border:2px solid var(--border);border-radius:12px;color:var(--text);font-size:.9rem;font-weight:600;cursor:pointer;transition:all .2s;text-align:left;}
.option-btn:hover{border-color:rgba(124,58,237,.4);background:rgba(124,58,237,.08);}
.option-btn.selected{border-color:var(--purple);background:rgba(124,58,237,.15);color:#a78bfa;}
.option-btn.correct{border-color:#22c55e;background:rgba(34,197,94,.15);color:#4ade80;}
.option-btn.wrong{border-color:#ef4444;background:rgba(239,68,68,.15);color:#f87171;}
.option-btn:disabled{cursor:default;opacity:.8;}
.timer{text-align:center;font-size:2.5rem;font-weight:800;color:#a78bfa;margin-bottom:20px;}
.timer.urgent{color:#f87171;}
.status{text-align:center;padding:16px;border-radius:12px;font-size:.9rem;font-weight:600;margin-top:16px;}
.status.waiting{background:rgba(124,58,237,.1);border:1px solid rgba(124,58,237,.2);color:#a78bfa;}
.status.success{background:rgba(34,197,94,.1);border:1px solid rgba(34,197,94,.2);color:#4ade80;}
.status.error{background:rgba(239,68,68,.1);border:1px solid rgba(239,68,68,.2);color:#f87171;}
.btn{padding:.75rem 1.5rem;border:none;border-radius:10px;font-size:.9rem;font-weight:700;cursor:pointer;transition:all .2s;font-family:inherit;}
.btn-primary{background:linear-gradient(135deg,var(--purple),var(--purple2));color:#fff;}
.btn-primary:hover{opacity:.9;}
.btn-danger{background:rgba(239,68,68,.15);border:1px solid rgba(239,68,68,.3);color:#f87171;}
.btn-danger:hover{background:rgba(239,68,68,.25);}
.btn:disabled{opacity:.5;cursor:default;}
.answer-item{display:flex;align-items:center;justify-content:space-between;padding:10px 14px;background:var(--surface2);border-radius:8px;margin-bottom:6px;font-size:.83rem;}
.teacher-controls{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:20px;padding-top:10px;border-top:1px solid var(--border);}
.fg{margin-bottom:14px;}
.fg label{display:block;font-size:.7rem;font-weight:600;text-transform:uppercase;letter-spacing:.06em;color:var(--muted);margin-bottom:6px;}
.fg input,.fg textarea,.fg select{width:100%;background:#111;border:1px solid rgba(255,255,255,.1);border-radius:9px;padding:.65rem .9rem;color:#fff;font-size:.88rem;font-family:inherit;outline:none;}
.fg textarea{resize:vertical;min-height:80px;}
.options-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:14px;}
.opt-input{background:#111;border:1px solid rgba(255,255,255,.1);border-radius:9px;padding:.6rem .9rem;color:#fff;font-size:.85rem;font-family:inherit;outline:none;width:100%;}
.participant-chip{background:rgba(124,58,237,.15);border:1px solid rgba(124,58,237,.2);border-radius:20px;padding:4px 12px;font-size:.75rem;color:#a78bfa;display:inline-block;margin:3px;}
.participants{margin-top:12px;}
.back-btn{display:inline-flex;align-items:center;gap:6px;color:var(--muted);text-decoration:none;font-size:.82rem;margin-bottom:20px;transition:color .2s;}
.back-btn:hover{color:var(--text);}
/* Anti cheat overlays */
#lockdown-overlay, #kicked-overlay {position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.95);z-index:9999;display:flex;flex-direction:column;align-items:center;justify-content:center;color:#fff;}
.lockdown-box {background:var(--surface);border:1px solid var(--purple);padding:40px;border-radius:20px;text-align:center;max-width:500px;}
.kicked-box {background:var(--surface);border:1px solid #ef4444;padding:40px;border-radius:20px;text-align:center;max-width:500px;}
.kicked-box h1 {color:#ef4444;margin-bottom:10px;}
.q-list-item {display:flex;align-items:center;justify-content:space-between;background:var(--surface2);padding:10px;border-radius:8px;margin-bottom:8px;border:1px solid var(--border);}
</style>
</head>
<body>
<div class="quiz-container">
  <a class="back-btn" href="/@(role == "teacher" ? "Teacher" : "Student")/Dashboard">← Back to Dashboard</a>
  <div class="header">
    <h1>⚡ Live Quiz</h1>
    <p>Real-time quiz powered by SignalR &nbsp;·&nbsp; @name (@role)</p>
  </div>

  @if (role == "teacher")
  {
    <div id="teacher-panel">
      <!-- Quiz Setup -->
      <div class="card" id="quiz-setup-card" style="margin-bottom:18px;">
        <div style="font-size:.85rem;font-weight:700;color:var(--text);margin-bottom:16px;">⚙️ Quiz Settings</div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
            <div class="fg"><label>Subject</label><input type="text" id="quiz-subject" placeholder="e.g. DBMS" /></div>
            <div class="fg"><label>Max Score (Total)</label><input type="number" id="quiz-max-score" value="150" /></div>
        </div>
        
        <hr style="border:none;border-top:1px solid var(--border);margin:20px 0;"/>
        
        <div style="font-size:.85rem;font-weight:700;color:var(--text);margin-bottom:16px;">📝 Add Question</div>
        <div class="fg"><label>Question</label><textarea id="q-text" placeholder="Enter your question here..."></textarea></div>
        <div style="font-size:.7rem;font-weight:600;text-transform:uppercase;letter-spacing:.06em;color:var(--muted);margin-bottom:8px;">Answer Options</div>
        <div class="options-grid">
          <input class="opt-input" id="opt-0" placeholder="Option A"/>
          <input class="opt-input" id="opt-1" placeholder="Option B"/>
          <input class="opt-input" id="opt-2" placeholder="Option C"/>
          <input class="opt-input" id="opt-3" placeholder="Option D"/>
        </div>
        <div class="fg">
          <label>Correct Answer</label>
          <select id="correct-ans">
            <option value="0">Option A</option>
            <option value="1">Option B</option>
            <option value="2">Option C</option>
            <option value="3">Option D</option>
          </select>
        </div>
        <div class="fg"><label>Time Limit (seconds)</label><input id="q-time" type="number" value="30" min="10" max="120"/></div>
        
        <button class="btn" style="width:100%;background:rgba(255,255,255,.08);color:#fff;" onclick="queueQuestion()">➕ Add Question to Queue</button>
        
        <div id="q-queue" style="margin-top:20px;"></div>
        
        <div style="margin-top:20px;display:flex;justify-content:center;">
          <button class="btn btn-primary" id="btn-start-quiz" onclick="startPrebuiltQuiz()" style="width:100%;font-size:1.1rem;padding:15px;" disabled>▶ Start Live Quiz</button>
        </div>
      </div>

      <!-- Live Operations (Hidden until start) -->
      <div id="live-operation-card" style="display:none;">
          <div class="card" style="margin-bottom:18px;">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:15px;">
                <div style="font-size:1.1rem;font-weight:800;color:#a78bfa;">🟢 Live Quiz Running</div>
                <div id="live-q-counter" style="font-weight:700;color:var(--muted);">Q 1 / X</div>
            </div>
            
            <div class="teacher-controls">
              <button class="btn btn-primary" id="btn-send-curr" onclick="sendCurrentQuestion()">▶ Send Question to Students</button>
              <button class="btn btn-danger" id="btn-reveal" onclick="revealAnswer()" disabled>✅ Reveal Answer</button>
              <button class="btn" id="btn-next" style="background:rgba(255,255,255,.06);color:var(--muted);" onclick="nextQuestion()" disabled>⏭ Next Question</button>
              <button class="btn btn-danger" id="btn-end" onclick="endQuiz()">⏹ End Quiz & Save Marks</button>
            </div>
          </div>
          <div class="card">
            <div style="font-size:.85rem;font-weight:700;margin-bottom:12px;">📊 Live Answers</div>
            <div id="live-answers"><p style="color:var(--muted);font-size:.82rem;">Waiting for students to answer...</p></div>
            <div style="font-size:.85rem;font-weight:700;margin-top:20px;margin-bottom:8px;">👥 Connected Students Tracking</div>
            <div id="participants" class="participants"><p style="color:var(--muted);font-size:.78rem;">No students yet</p></div>
          </div>
      </div>
    </div>
  }
  else
  {
    <div id="student-panel">
      <div id="waiting-screen" class="card">
        <div class="status waiting">⏳ Waiting for teacher to start the quiz...</div>
        <p style="color:var(--muted);font-size:.82rem;text-align:center;margin-top:16px;">Stay on this page. The question will appear automatically.</p>
      </div>
      <div id="question-screen" class="card" style="display:none;">
        <div class="timer" id="countdown">30</div>
        <div class="question-text" id="question-display"></div>
        <div class="options" id="options-display"></div>
        <div id="answer-status" class="status" style="display:none;"></div>
      </div>
      <div id="result-screen" class="card" style="display:none;">
        <div style="text-align:center;padding:20px;">
          <div style="font-size:3rem;margin-bottom:12px;" id="result-emoji">🎉</div>
          <div style="font-size:1.3rem;font-weight:800;" id="result-text">Correct!</div>
          <div style="color:var(--muted);margin-top:8px;font-size:.85rem;" id="result-sub"></div>
        </div>
      </div>
    </div>
  }
</div>

@if (role != "teacher")
{
    <!-- Lockdown Overlay -->
    <div id="lockdown-overlay">
        <div class="lockdown-box">
            <h1 style="color:#a78bfa;margin-bottom:15px;">🔒 Ready to Join Quiz?</h1>
            <p style="color:var(--muted);margin-bottom:20px;">This forces Fullscreen Mode. Once started, do not switch tabs, exit fullscreen, right-click, or use shortcuts. Doing so will instantly disqualify you from the quiz.</p>
            <button class="btn btn-primary" onclick="enterLockdown()" style="width:100%;font-size:1.2rem;padding:15px;">Enter Lockdown & Join</button>
        </div>
    </div>

    <!-- Kicked Overlay -->
    <div id="kicked-overlay" style="display:none;">
        <div class="kicked-box">
            <h1>🚫 CHEATING DETECTED</h1>
            <p style="color:var(--muted);margin-bottom:20px;">You have stepped out of lockdown mode or switched tabs. Your session has been terminated and the teacher has been notified.</p>
            <a href="/Student/Dashboard" class="btn" style="background:#555;color:#fff;text-decoration:none;">Return to Dashboard</a>
        </div>
    </div>
}

<script>
var connection=new signalR.HubConnectionBuilder().withUrl("/quizHub").withAutomaticReconnect().build();
var role="@role";
var myName="@name";
var myUid="@uid";

// Teacher state
var questionsQueue = [];
var currentQIndex = 0;
// studentScores[uid] = { name: "John", score: 0, kicked: false }
var studentScores = {}; 
var currentAnswers = {}; // To evaluate current question answers 

// Student state
var currentOptions=[],correctAnswer=-1,myAnswer=-1,timerInterval=null;
var isLockdownValid = false;
var kicked = false;


connection.start().then(function(){console.log("SignalR connected");}).catch(function(err){console.error(err);});

// ----------------- SIGNALR LISTENERS -----------------
connection.on("ReceiveQuestion",function(question,options,timeSeconds){
  currentOptions=options;myAnswer=-1;correctAnswer=-1;currentAnswers={};
  if(role==="student"){
    if(!isLockdownValid) return; // Prevent joining if didn't accept lockdown
    document.getElementById('waiting-screen').style.display='none';
    document.getElementById('result-screen').style.display='none';
    document.getElementById('question-screen').style.display='block';
    document.getElementById('question-display').textContent=question;
    document.getElementById('answer-status').style.display='none';
    document.getElementById('options-display').innerHTML=options.map(function(opt,i){
      return '<button class="option-btn" onclick="selectAnswer('+i+')" id="opt-btn-'+i+'"><span style="font-weight:800;margin-right:8px;color:#a78bfa;">'+'ABCD'[i]+'.</span>'+opt+'</button>';
    }).join('');
    startTimer(timeSeconds);
  }
  if(role==="teacher"){
    document.getElementById('live-answers').innerHTML='<p style="color:var(--muted);font-size:.82rem;">Waiting for students to answer...</p>';
  }
});

connection.on("ReceiveAnswer",function(studentUid, studentName,answerIndex){
  if(role==="teacher"){
    currentAnswers[studentUid]=answerIndex;
    if(!studentScores[studentUid]) studentScores[studentUid] = { name: studentName, score: 0, kicked: false };
    
    document.getElementById('live-answers').innerHTML=Object.entries(currentAnswers).map(function(e){
      var sName = studentScores[e[0]].name;
      return '<div class="answer-item"><span style="font-weight:600;">'+sName+'</span><span class="participant-chip">'+'ABCD'[e[1]]+'</span></div>';
    }).join('');
    renderParticipants();
  }
});

connection.on("StudentCheatedNotify", function(studentUid, studentName) {
    if(role==="teacher"){
        if(!studentScores[studentUid]) studentScores[studentUid] = { name: studentName, score: 0, kicked: true };
        else studentScores[studentUid].kicked = true;
        renderParticipants();
    }
});

connection.on("AnswerRevealed",function(correct){
  correctAnswer=correct;
  if(role==="student"){
    clearInterval(timerInterval);
    document.querySelectorAll('.option-btn').forEach(function(b){b.disabled=true;});
    if(myAnswer===correct){document.getElementById('opt-btn-'+correct).classList.add('correct');showResult(true,correct);}
    else{if(myAnswer>=0)document.getElementById('opt-btn-'+myAnswer).classList.add('wrong');document.getElementById('opt-btn-'+correct).classList.add('correct');showResult(false,correct);}
  }
  if(role==="teacher"){
    // Evaluate scores permanently into studentScores
    for(var sUid in currentAnswers){
        if(currentAnswers[sUid] === correct && !studentScores[sUid].kicked){
            studentScores[sUid].score += 1; // +1 correctly assigned
        }
    }
    
    document.getElementById('live-answers').innerHTML=Object.entries(currentAnswers).map(function(e){
      var sUid = e[0];
      var idx = e[1];
      var sName = studentScores[sUid].name;
      var isCorrect = (idx===correct);
      return '<div class="answer-item"><span style="font-weight:600;">'+sName+'</span><span class="participant-chip" style="'+(isCorrect?'background:rgba(34,197,94,.15);color:#4ade80;':'background:rgba(239,68,68,.15);color:#f87171;')+'">'+'ABCD'[idx]+(isCorrect?' ✅':' ❌')+'</span></div>';
    }).join('');
    
    renderParticipants(); // Redraw scores
  }
});

connection.on("QuestionReset",function(){
  if(role==="student" && isLockdownValid){
    clearInterval(timerInterval);
    document.getElementById('question-screen').style.display='none';
    document.getElementById('result-screen').style.display='none';
    document.getElementById('waiting-screen').style.display='block';
  }
  if(role==="teacher"){
      currentAnswers={};
      document.getElementById('live-answers').innerHTML='<p style="color:var(--muted);font-size:.82rem;">Waiting for students to answer...</p>';
  }
});

connection.on("QuizEnded",function(resultsJson){
  if(role==="student"){
    clearInterval(timerInterval);
    document.exitFullscreen().catch(()=>{});
    document.getElementById('question-screen').style.display='none';
    document.getElementById('result-screen').style.display='none';
    document.getElementById('waiting-screen').innerHTML='<div class="status success" style="font-size:1rem;">🎉 Quiz ended! Marks automatically updated on Dashboard!</div><br/><a href="/Student/Dashboard" class="btn" style="background:#4ade80;color:#000;text-decoration:none;">Go back</a>';
    document.getElementById('waiting-screen').style.display='block';
  }
});

// ----------------- STUDENT LOCKDOWN ENGINE -----------------
async function enterLockdown() {
    try {
        await document.documentElement.requestFullscreen();
        isLockdownValid = true;
        document.getElementById('lockdown-overlay').style.display = 'none';
    } catch(e) {
        alert('Fullscreen is required to take this quiz. Please allow fullscreen permissions.');
        console.error(e);
    }
}

if(role !== "teacher"){
    // Security Listeners
    document.addEventListener("contextmenu", e => e.preventDefault());
    document.addEventListener("copy", e => e.preventDefault());
    document.addEventListener("paste", e => e.preventDefault());
    
    document.addEventListener("fullscreenchange", function() {
       if(!document.fullscreenElement && isLockdownValid && !kicked) triggerCheat();
    });
    
    document.addEventListener("visibilitychange", function() {
        if(document.visibilityState === "hidden" && isLockdownValid && !kicked) triggerCheat();
    });
    
    window.addEventListener("blur", function() {
        if(isLockdownValid && !kicked) triggerCheat(); 
    });

    function triggerCheat() {
        kicked = true;
        isLockdownValid = false;
        connection.invoke("StudentCheated", myUid, myName);
        document.getElementById('kicked-overlay').style.display = 'flex';
        // Kick out of fullscreen
        if(document.fullscreenElement) document.exitFullscreen().catch(()=>{});
    }
}

// ----------------- SHARED & STUDENT LOGIC -----------------
function startTimer(seconds){
  clearInterval(timerInterval);
  var left=seconds;
  document.getElementById('countdown').textContent=left;
  document.getElementById('countdown').className='timer';
  timerInterval=setInterval(function(){
    left--;
    document.getElementById('countdown').textContent=left;
    if(left<=10)document.getElementById('countdown').className='timer urgent';
    if(left<=0){
      clearInterval(timerInterval);
      document.querySelectorAll('.option-btn').forEach(function(b){b.disabled=true;});
      var s=document.getElementById('answer-status');s.textContent="⏰ Time's up!";s.className='status error';s.style.display='block';
    }
  },1000);
}

function selectAnswer(index){
  if(myAnswer>=0 || kicked)return;
  myAnswer=index;
  document.querySelectorAll('.option-btn').forEach(function(b){b.classList.remove('selected');});
  document.getElementById('opt-btn-'+index).classList.add('selected');
  connection.invoke("SubmitAnswer",myUid,myName,index);
  var s=document.getElementById('answer-status');s.textContent="✅ Answer submitted! Waiting for teacher to reveal...";s.className='status success';s.style.display='block';
}

function showResult(correct,correctIdx){
  setTimeout(function(){
    document.getElementById('question-screen').style.display='none';
    document.getElementById('result-screen').style.display='block';
    document.getElementById('result-emoji').textContent=correct?'🎉':'😔';
    document.getElementById('result-text').textContent=correct?'Correct!':'Wrong Answer';
    document.getElementById('result-text').style.color=correct?'#4ade80':'#f87171';
    document.getElementById('result-sub').textContent=correct?'Great job! The answer was '+'ABCD'[correctIdx]+'.':'The correct answer was '+'ABCD'[correctIdx]+': '+currentOptions[correctIdx];
  },1500);
}

// ----------------- TEACHER LOGIC -----------------
function queueQuestion(){
  var q=document.getElementById('q-text').value.trim();
  var opts=['opt-0','opt-1','opt-2','opt-3'].map(id=>document.getElementById(id).value.trim());
  var time=parseInt(document.getElementById('q-time').value)||30;
  var cAnswer=parseInt(document.getElementById('correct-ans').value);
  
  if(!q || opts.some(o=>!o)){alert('Please fill in question and all 4 options.');return;}
  
  questionsQueue.push({ q: q, opts: opts, time: time, answer: cAnswer });
  
  // Clear form
  document.getElementById('q-text').value='';
  ['opt-0','opt-1','opt-2','opt-3'].forEach(id=>document.getElementById(id).value='');
  
  renderQueue();
  document.getElementById('btn-start-quiz').disabled = false;
}

function renderQueue(){
    var html = '';
    questionsQueue.forEach((item, idx) => {
        html += '<div class="q-list-item"><div><strong>Q'+(idx+1)+':</strong> '+item.q.substring(0, 30)+'...</div><span class="badge b-ok" style="font-size:0.7rem;color:#4ade80;">'+item.time+'s</span></div>';
    });
    document.getElementById('q-queue').innerHTML = html;
}

function renderParticipants() {
    var html = Object.keys(studentScores).map(function(sUid) {
        var p = studentScores[sUid];
        if(p.kicked) return '<div class="participant-chip" style="background:rgba(239,68,68,.1) !important; color:#ef4444; border-color:#ef4444;">'+p.name+' 🚫 KICKED</div>';
        return '<div class="participant-chip">'+p.name+' ⭐ '+p.score+'</div>';
    }).join('');
    document.getElementById('participants').innerHTML = html || '<p style="color:var(--muted);font-size:.78rem;">No students yet</p>';
}

function startPrebuiltQuiz(){
    if(!document.getElementById('quiz-subject').value.trim()){ alert("Provide a Subject!"); return; }
    document.getElementById('quiz-setup-card').style.display='none';
    document.getElementById('live-operation-card').style.display='block';
    currentQIndex = 0;
    updateCounter();
}

function updateCounter() {
    document.getElementById('live-q-counter').textContent = 'Question ' + (currentQIndex + 1) + ' / ' + questionsQueue.length;
}

function sendCurrentQuestion() {
    var currentQ = questionsQueue[currentQIndex];
    document.getElementById('btn-send-curr').disabled = true;
    document.getElementById('btn-reveal').disabled = false;
    document.getElementById('btn-next').disabled = true;
    connection.invoke("SendQuestion", currentQ.q, currentQ.opts, currentQ.time);
}

function revealAnswer(){
    document.getElementById('btn-reveal').disabled = true;
    var currentQ = questionsQueue[currentQIndex];
    connection.invoke("RevealAnswer", currentQ.answer);
    
    // If not last question, enable Next. Else just leave End Quiz enabled.
    if(currentQIndex < questionsQueue.length - 1) {
        document.getElementById('btn-next').disabled = false;
    }
}

function nextQuestion(){
    currentQIndex++;
    updateCounter();
    document.getElementById('btn-next').disabled = true;
    document.getElementById('btn-send-curr').disabled = false;
    connection.invoke("NextQuestion");
}

async function endQuiz(){
    if(!confirm("Are you sure you want to end the Quiz and save marks automatically?")) return;
    document.getElementById('btn-end').disabled = true;
    document.getElementById('btn-end').textContent = "Saving...";
    
    var maxScore = parseInt(document.getElementById('quiz-max-score').value) || 150;
    var subjectName = document.getElementById('quiz-subject').value.trim() || "Live Quiz";
    
    // Scale marks. E.g if 3 questions and maxScore = 150, 1 question = 50 marks.
    // If a student gets 2 right, their raw score is 2. Scaled score = (2 / 3) * 150 = 100.
    var totalQuestions = questionsQueue.length;
    var bulkPayload = [];
    
    for(var sUid in studentScores) {
        if(studentScores[sUid].kicked) {
            // Disqualified gets 0
             bulkPayload.push({
                StudentUid: sUid,
                SubjectName: subjectName,
                ExamType: "Quiz",
                Score: 0,
                MaxScore: maxScore
            });
        } else {
            var rawCorrect = studentScores[sUid].score;
            var scaledScore = totalQuestions > 0 ? (rawCorrect * maxScore) / totalQuestions : 0;
            bulkPayload.push({
                StudentUid: sUid,
                SubjectName: subjectName,
                ExamType: "Quiz",
                Score: parseFloat(scaledScore.toFixed(2)),
                MaxScore: maxScore
            });
        }
    }
    
    // Save Bulk Marks to DB
    try {
        if(bulkPayload.length > 0) {
            var resp = await fetch('/Marks/SaveBulk', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(bulkPayload)
            });
            if(resp.ok) {
                alert("Quiz marks saved successfully to the database!");
            } else {
                alert("Quiz ended, but there was an error saving marks.");
            }
        }
    } catch(e) {
        console.error(e);
        alert("Network error saving marks.");
    }
    
    // Notify students
    connection.invoke("EndQuiz", JSON.stringify(studentScores));
}
</script>
</body>
</html>