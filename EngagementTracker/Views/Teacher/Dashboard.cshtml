let currentSessionId = null;

// On page load, check if a session is already running
fetch('/LiveClass/GetActiveSession').then(r=>r.json()).then(d=>{
  if(d.isLive){
    currentSessionId = d.sessionId;
    document.getElementById('live-status').textContent = '🟢 Class LIVE';
    document.getElementById('live-status').style.color = '#22c55e';
    document.getElementById('join-btn').style.display = 'block';
  }
});

async function startLiveClass() {
  const subject  = document.getElementById('live-subject').value.trim();
  const duration = parseInt(document.getElementById('durationInput')?.value || '60');

  if (!subject) { alert('Enter subject name first'); return; }

  const res  = await fetch('/LiveClass/StartClass', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ subject, durationMinutes: duration })
  });
  const data = await res.json();

  if (data.success) {
    currentSessionId = data.sessionId;
    document.getElementById('live-status').textContent = '🟢 Class LIVE';
    document.getElementById('live-status').style.color = '#22c55e';
    document.getElementById('join-btn').style.display = 'block';
    alert('✅ Class started! Students who attend 80%+ will be auto-marked Present.');
  }
}

async function joinLiveMeeting() {
  window.open('/LiveClass/Index', '_blank');
}

async function endLiveClass() {
  if (!currentSessionId) { alert('No active session'); return; }

  const res  = await fetch('/LiveClass/EndClass', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ sessionId: currentSessionId })
  });
  const data = await res.json();

  if (data.success) {
    currentSessionId = null;
    document.getElementById('live-status').textContent = '🔴 Not Live';
    document.getElementById('live-status').style.color = '#ef4444';
    document.getElementById('join-btn').style.display = 'none';
    alert('✅ Class ended! Eligible students have been auto-marked Present.');
  }
}

// ─── Timetable Logic ───────────────────────────────────────────────────────
let currentTimetable = [];
let currentTtSection = "";

async function loadSectionTimetable() {
  const sec = document.getElementById("tt-section-select").value;
  if(!sec){ alert('Please select a section.'); return; }
  currentTtSection = sec;
  document.getElementById("lbl-tt-section").innerText = sec;
  document.getElementById("timetable-builder").style.display = 'block';
  
  const res = await fetch(`/Timetable/Get?section=${sec}`);
  if(res.ok) {
    currentTimetable = await res.json();
    renderTimetableBuilder();
  } else {
    alert("Could not load timetable.");
  }
}

function renderTimetableBuilder() {
  const tbody = document.getElementById("tt-tbody");
  tbody.innerHTML = "";
  if(currentTimetable.length === 0){
     tbody.innerHTML = `<tr><td colspan="7" class="empty">No classes scheduled yet. Add one!</td></tr>`;
     return;
  }
  
  const daysOrder = { "Monday":1, "Tuesday":2, "Wednesday":3, "Thursday":4, "Friday":5 };
  currentTimetable.sort((a,b) => (daysOrder[a.dayOfWeek] || 99) - (daysOrder[b.dayOfWeek] || 99) || a.startTime.localeCompare(b.startTime));

  currentTimetable.forEach((entry, index) => {
     const tr = document.createElement("tr");
     tr.innerHTML = `
        <td>
           <select class="t-input" onchange="updateTt(${index}, 'dayOfWeek', this.value)">
              <option value="Monday" ${entry.dayOfWeek==='Monday'?'selected':''}>Monday</option>
              <option value="Tuesday" ${entry.dayOfWeek==='Tuesday'?'selected':''}>Tuesday</option>
              <option value="Wednesday" ${entry.dayOfWeek==='Wednesday'?'selected':''}>Wednesday</option>
              <option value="Thursday" ${entry.dayOfWeek==='Thursday'?'selected':''}>Thursday</option>
              <option value="Friday" ${entry.dayOfWeek==='Friday'?'selected':''}>Friday</option>
           </select>
        </td>
        <td><input type="time" class="t-input" value="${entry.startTime}" onchange="updateTt(${index}, 'startTime', this.value)"></td>
        <td><input type="time" class="t-input" value="${entry.endTime}" onchange="updateTt(${index}, 'endTime', this.value)"></td>
        <td><input type="text" class="t-input" value="${entry.subject}" onchange="updateTt(${index}, 'subject', this.value)" placeholder="Subject (e.g. DSA)"></td>
        <td><input type="text" class="t-input" value="${entry.room}" onchange="updateTt(${index}, 'room', this.value)" placeholder="Room"></td>
        <td><input type="text" class="t-input" value="${entry.teacherName}" onchange="updateTt(${index}, 'teacherName', this.value)" placeholder="Prof Name"></td>
        <td><button class="action-btn" style="color:#ef4444;" onclick="deleteTt(${index})">Delete</button></td>
     `;
     tbody.appendChild(tr);
  });
}

function addTimetableRow() {
  currentTimetable.push({ dayOfWeek: "Monday", startTime: "09:00", endTime: "10:00", subject: "", room: "", teacherName: "" });
  renderTimetableBuilder();
}

function updateTt(index, field, val) {
  currentTimetable[index][field] = val;
}

function deleteTt(index) {
  currentTimetable.splice(index, 1);
  renderTimetableBuilder();
}

async function saveSectionTimetable() {
  if(!currentTtSection) return;
  for(let m of currentTimetable) {
      if(!m.subject || !m.startTime || !m.endTime) {
          alert("All entries must have a Subject, Start Time, and End Time.");
          return;
      }
  }
  
  const res = await fetch(`/Timetable/Save?section=${currentTtSection}`, {
     method: 'POST',
     headers: { 'Content-Type' : 'application/json' },
     body: JSON.stringify(currentTimetable)
  });
  
  if(res.ok) {
     alert("✅ Timetable successfully saved to Firestore!");
  } else {
     alert("❌ Error saving timetable.");
  }
}

