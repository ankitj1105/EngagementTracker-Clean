  <!-- Javascript Logic -->
  <script>
    // Toggle role dashboard
    function switchRole(role) {
      // Toggle button states
      document.querySelectorAll('.role-switcher .role-btn').forEach(btn => btn.classList.remove('active'));
      
      const buttons = document.querySelectorAll('.role-switcher .role-btn');
      
      // Hide all sidebars and portal contents
      document.getElementById('sidebar-student').style.display = 'none';
      document.getElementById('sidebar-teacher').style.display = 'none';
      document.getElementById('sidebar-admin').style.display = 'none';
      
      document.getElementById('portal-student').classList.remove('active');
      document.getElementById('portal-teacher').classList.remove('active');
      document.getElementById('portal-admin').classList.remove('active');
      
      // Remove body dark mode if active
      document.body.classList.remove('dark-mode');

      // Switch
      if (role === 'student') {
        buttons[0].classList.add('active');
        document.getElementById('sidebar-student').style.display = 'flex';
        document.getElementById('portal-student').classList.add('active');
      } else if (role === 'teacher') {
        buttons[1].classList.add('active');
        document.getElementById('sidebar-teacher').style.display = 'flex';
        document.getElementById('portal-teacher').classList.add('active');
      } else if (role === 'admin') {
        buttons[2].classList.add('active');
        document.getElementById('sidebar-admin').style.display = 'flex';
        document.getElementById('portal-admin').classList.add('active');
        // Enable dark mode for Admin view
        document.body.classList.add('dark-mode');
      }
    }

    // Toggle live class simulation from Teacher Dashboard
    function toggleDemoClass(isLive) {
      const dot = document.getElementById('demo-class-dot');
      const text = document.getElementById('demo-class-text');
      const studentAlert = document.getElementById('student-live-alert');

      if (isLive) {
        dot.classList.add('active');
        text.textContent = 'Live (Duration: ' + document.getElementById('class-duration').value + 'm)';
        text.style.color = 'var(--success)';
        
        // Show class banner in student portal view
        studentAlert.style.display = 'flex';
        
        alert('Simulated class started! Switch to the Student Portal view to see the Live Class banner.');
      } else {
        dot.classList.remove('active');
        text.textContent = 'Not Live';
        text.style.color = '';
        
        // Hide banner in student portal
        studentAlert.style.display = 'none';
      }
    }

    // Hover Guided Tour Event listeners
    const tooltip = document.getElementById('demo-tooltip');
    const guideTitle = document.getElementById('guide-item-title');
    const guideDesc = document.getElementById('guide-item-desc');

    document.addEventListener('mouseover', function(e) {
      const target = e.target.closest('.demo-tour-item');
      if (target) {
        const title = target.getAttribute('data-tour-title');
        const desc = target.getAttribute('data-tour-desc');
        
        // Update floating helper details
        guideTitle.textContent = title;
        guideDesc.textContent = desc;

        // Position & show mini floating tooltip bubble
        tooltip.textContent = title;
        const rect = target.getBoundingClientRect();
        
        // Horizontal center alignment
        tooltip.style.left = (rect.left + window.scrollX + rect.width / 2) + 'px';
        tooltip.style.top = (rect.top + window.scrollY - 6) + 'px';
        tooltip.classList.add('visible');
      }
    });

    document.addEventListener('mouseout', function(e) {
      const target = e.target.closest('.demo-tour-item');
      if (target) {
        tooltip.classList.remove('visible');
      }
    });
  </script>
</body>
</html>
