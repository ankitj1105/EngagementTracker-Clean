@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title>Application Demo &amp; Guided Tour — EngageTracker</title>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800;900&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      background: #f4f7fe;
      font-family: 'Outfit', sans-serif;
      color: #2b3674;
      min-height: 100vh;
      overflow-x: hidden;
    }
    
    /* Variables */
    :root {
      --primary: #4318ff;
      --primary-rgb: 67, 24, 255;
      --secondary: #7b59d9;
      --success: #05cd99;
      --danger: #ee5d50;
      --warning: #ffce20;
      --info: #39b8ff;
      --sidebar-bg: #5b37b7;
      --sidebar-text: #d4c6f5;
      --sidebar-active: #7b59d9;
      --text-main: #2b3674;
      --text-muted: #a3aed1;
      --border: #e2e8f0;
      --card-shadow: 0 10px 30px rgba(0, 0, 0, 0.03);
    }

    /* Top Control Bar */
    .demo-bar {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      height: 65px;
      background: rgba(14, 14, 26, 0.95);
      backdrop-filter: blur(10px);
      z-index: 1000;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 2rem;
      border-bottom: 2px solid rgba(124, 58, 237, 0.3);
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
    }
    .demo-logo {
      color: #fff;
      font-weight: 800;
      font-size: 1.2rem;
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .demo-logo span {
      background: linear-gradient(135deg, #a78bfa, #7c3aed);
      color: #fff;
      padding: 4px 8px;
      border-radius: 6px;
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.05em;
    }
    .role-switcher {
      display: flex;
      background: rgba(255, 255, 255, 0.08);
      padding: 4px;
      border-radius: 30px;
      border: 1px solid rgba(255, 255, 255, 0.15);
    }
    .role-btn {
      padding: 6px 18px;
      border: none;
      background: transparent;
      color: rgba(255, 255, 255, 0.7);
      font-family: 'Outfit', sans-serif;
      font-weight: 600;
      font-size: 0.88rem;
      cursor: pointer;
      border-radius: 20px;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .role-btn:hover {
      color: #fff;
    }
    .role-btn.active {
      background: #7c3aed;
      color: #fff;
      box-shadow: 0 4px 12px rgba(124, 58, 237, 0.3);
    }
    .exit-demo-btn {
      background: transparent;
      border: 1px solid rgba(255, 255, 255, 0.25);
      color: #fff;
      padding: 6px 16px;
      border-radius: 30px;
      font-family: 'Outfit', sans-serif;
      font-weight: 550;
      font-size: 0.85rem;
      text-decoration: none;
      transition: all 0.2s;
    }
    .exit-demo-btn:hover {
      background: #ee5d50;
      border-color: #ee5d50;
      box-shadow: 0 4px 12px rgba(238, 93, 80, 0.25);
    }

    /* Layout Wrapper */
    .dashboard-wrapper {
      margin-top: 65px;
      display: flex;
      min-height: calc(100vh - 65px);
    }

    /* Sidebar styles */
    .sidebar {
      width: 260px;
      background: var(--sidebar-bg);
      display: flex;
      flex-direction: column;
      border-top-right-radius: 20px;
      border-bottom-right-radius: 20px;
      box-shadow: 4px 0 24px rgba(0, 0, 0, 0.03);
      position: fixed;
      left: 0;
      top: 65px;
      bottom: 0;
      z-index: 100;
      transition: all 0.3s;
    }
    .sidebar-brand {
      padding: 24px;
      color: #fff;
      font-size: 1.1rem;
      font-weight: 700;
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }
    .sidebar-brand span {
      display: block;
      font-size: 0.72rem;
      color: rgba(255, 255, 255, 0.5);
      font-weight: 500;
      margin-top: 2px;
    }
    .sidebar-menu {
      padding: 16px 0;
      flex: 1;
      overflow-y: auto;
    }
    .sidebar-section {
      font-size: 0.65rem;
      font-weight: 700;
      color: rgba(255, 255, 255, 0.4);
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 12px 24px 6px;
    }
    .menu-item {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px 24px;
      color: var(--sidebar-text);
      text-decoration: none;
      font-size: 0.9rem;
      font-weight: 500;
      cursor: pointer;
      border-left: 4px solid transparent;
      transition: all 0.2s;
    }
    .menu-item:hover {
      color: #fff;
      background: rgba(255, 255, 255, 0.04);
    }
    .menu-item.active {
      color: #fff;
      background: var(--sidebar-active);
      border-left-color: #fff;
      border-radius: 0 10px 10px 0;
      margin-right: 16px;
    }

    /* Main Area */
    .main-content {
      flex: 1;
      margin-left: 260px;
      padding: 2rem;
      overflow-y: auto;
    }

    /* Stats Grid */
    .stat-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 1.5rem;
      margin-bottom: 2rem;
    }
    .stat-card {
      background: #fff;
      border-radius: 15px;
      padding: 1.25rem;
      display: flex;
      align-items: center;
      gap: 1rem;
      box-shadow: var(--card-shadow);
      border: 1px solid var(--border);
    }
    .stat-icon {
      width: 48px;
      height: 48px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.3rem;
    }
    .stat-icon.pu { background: rgba(67, 24, 255, 0.08); color: var(--primary); }
    .stat-icon.gr { background: rgba(5, 205, 153, 0.08); color: var(--success); }
    .stat-icon.pi { background: rgba(238, 93, 80, 0.08); color: var(--danger); }
    .stat-icon.bl { background: rgba(57, 184, 255, 0.08); color: var(--info); }
    .stat-details h3 {
      font-size: 1.4rem;
      font-weight: 700;
      color: var(--text-main);
    }
    .stat-details p {
      font-size: 0.8rem;
      color: var(--text-muted);
      font-weight: 500;
      margin-top: 2px;
    }

    /* Dashboard Layout Grid */
    .dashboard-grid {
      display: grid;
      grid-template-columns: 2fr 1fr;
      gap: 1.5rem;
      margin-bottom: 2rem;
    }
    @@media (max-width: 992px) {
      .dashboard-grid { grid-template-columns: 1fr; }
    }
    .card {
      background: #fff;
      border-radius: 15px;
      border: 1px solid var(--border);
      box-shadow: var(--card-shadow);
      padding: 1.5rem;
      position: relative;
    }
    .card-title {
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--text-main);
      margin-bottom: 1.2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    /* Table styles */
    .table-container {
      width: 100%;
      overflow-x: auto;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      text-align: left;
      font-size: 0.88rem;
    }
    th {
      color: var(--text-muted);
      font-weight: 600;
      padding: 10px 16px;
      border-bottom: 1px solid var(--border);
      font-size: 0.78rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    td {
      padding: 12px 16px;
      border-bottom: 1px solid var(--border);
      color: var(--text-main);
      font-weight: 500;
    }
    tr:last-child td {
      border-bottom: none;
    }
    .user-profile {
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .user-avatar {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      background: #7c3aed;
      color: #fff;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      font-size: 0.85rem;
    }
    .badge {
      padding: 3px 8px;
      border-radius: 6px;
      font-size: 0.72rem;
      font-weight: 700;
    }
    .badge-success { background: rgba(5, 205, 153, 0.1); color: var(--success); }
    .badge-danger { background: rgba(238, 93, 80, 0.1); color: var(--danger); }
    .badge-warning { background: rgba(255, 206, 32, 0.15); color: #d4a000; }

    /* Floating Guide Helper Panel */
    .guide-panel {
      position: fixed;
      bottom: 25px;
      right: 25px;
      width: 360px;
      background: rgba(14, 14, 26, 0.95);
      border: 1px solid rgba(124, 58, 237, 0.5);
      box-shadow: 0 10px 40px rgba(124, 58, 237, 0.25);
      border-radius: 16px;
      padding: 1.25rem;
      z-index: 2000;
      color: #fff;
      backdrop-filter: blur(8px);
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .guide-title {
      font-weight: 800;
      font-size: 0.98rem;
      color: #a78bfa;
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 8px;
    }
    .guide-desc {
      font-size: 0.83rem;
      line-height: 1.45;
      color: rgba(255, 255, 255, 0.78);
    }
    .guide-footer {
      margin-top: 10px;
      font-size: 0.75rem;
      color: #8b5cf6;
      font-weight: 600;
      letter-spacing: 0.02em;
    }

    /* Live class card styling */
    .live-join-card {
      background: linear-gradient(135deg, #7c3aed, #4318ff);
      color: #fff;
      border-radius: 15px;
      padding: 1.5rem;
      margin-bottom: 2rem;
      box-shadow: 0 10px 25px rgba(67, 24, 255, 0.2);
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .live-text h3 {
      font-size: 1.25rem;
      font-weight: 700;
      margin-bottom: 4px;
    }
    .live-text p {
      font-size: 0.85rem;
      opacity: 0.85;
    }
    .live-btn {
      background: #fff;
      color: var(--primary);
      border: none;
      padding: 8px 18px;
      border-radius: 20px;
      font-weight: 700;
      font-size: 0.85rem;
      cursor: pointer;
      box-shadow: 0 4px 10px rgba(255, 255, 255, 0.2);
      transition: all 0.2s;
    }
    .live-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 14px rgba(255, 255, 255, 0.3);
    }

    /* Interactive highlights */
    .demo-tour-item {
      cursor: help;
      transition: all 0.25s ease;
      position: relative;
    }
    .demo-tour-item:hover {
      box-shadow: 0 0 0 3px rgba(124, 58, 237, 0.6) !important;
      transform: scale(1.01);
    }

    /* Tooltip Bubble */
    .demo-tooltip {
      position: absolute;
      background: #7c3aed;
      color: #fff;
      font-size: 0.72rem;
      font-weight: 700;
      padding: 4px 8px;
      border-radius: 5px;
      pointer-events: none;
      box-shadow: 0 4px 12px rgba(124, 58, 237, 0.3);
      z-index: 3000;
      transform: translate(-50%, -100%) scale(0.9);
      opacity: 0;
      transition: all 0.15s ease;
      white-space: nowrap;
    }
    .demo-tooltip::after {
      content: '';
      position: absolute;
      bottom: -4px;
      left: 50%;
      transform: translateX(-50%);
      border-width: 4px 4px 0;
      border-style: solid;
      border-color: #7c3aed transparent transparent;
    }
    .demo-tooltip.visible {
      opacity: 1;
      transform: translate(-50%, -100%) scale(1);
    }

    /* Section content toggler */
    .demo-view-section {
      display: none;
    }
    .demo-view-section.active {
      display: block;
      animation: fadeIn 0.4s ease-out;
    }
    @@keyframes fadeIn {
      from { opacity: 0; transform: translateY(8px); }
      to { opacity: 1; transform: translateY(0); }
    }

    /* AI Attendance camera mock styling */
    .camera-box {
      width: 100%;
      height: 250px;
      background: #0f0f1b;
      border-radius: 12px;
      position: relative;
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
      border: 2px solid rgba(124, 58, 237, 0.4);
    }
    .camera-overlay {
      position: absolute;
      inset: 0;
      border: 2px dashed rgba(5, 205, 153, 0.6);
      margin: 20px;
      border-radius: 8px;
      animation: pulseBorder 2s infinite alternate;
    }
    @@keyframes pulseBorder {
      0% { opacity: 0.3; }
      100% { opacity: 0.8; }
    }
    .scanning-line {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 2px;
      background: var(--success);
      box-shadow: 0 0 10px var(--success);
      animation: scan 3s infinite linear;
    }
    @@keyframes scan {
      0% { top: 0; }
      100% { top: 100%; }
    }

    /* Real-time quiz mock */
    .quiz-card {
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 1.25rem;
      background: #fafbfe;
      margin-top: 1rem;
    }
    .quiz-options {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      margin-top: 1rem;
    }
    .quiz-option {
      background: #fff;
      border: 1px solid var(--border);
      padding: 10px;
      border-radius: 8px;
      font-size: 0.82rem;
      cursor: pointer;
      text-align: center;
      transition: all 0.2s;
    }
    .quiz-option:hover {
      background: rgba(124, 58, 237, 0.08);
      border-color: var(--primary);
    }
  </style>
</head>
<body>

  <!-- Top Demo Control Bar -->
  <div class="demo-bar">
    <div class="demo-logo">
      📊 EngageTracker <span>GUIDED TOUR</span>
    </div>
    
    <div class="role-switcher">
      <button class="role-btn active" onclick="switchRole('teacher')">Teacher Portal</button>
      <button class="role-btn" onclick="switchRole('student')">Student Portal</button>
    </div>

    <a href="/Auth/Login" class="exit-demo-btn">Exit Demo</a>
  </div>

  <!-- Dashboard Container -->
  <div class="dashboard-wrapper">
    
    <!-- ==================== SIDEBARS ==================== -->
    
    <!-- Teacher Sidebar -->
    <div class="sidebar" id="sidebar-teacher">
      <div class="sidebar-brand">
        📊 EngageTracker
        <span>Teacher Control Panel</span>
      </div>
      <div class="sidebar-menu">
        <div class="sidebar-section">Main</div>
        <div class="menu-item active demo-tour-item" data-sec="t-dashboard" onclick="switchSec('t', 'dashboard')" data-tour-title="Teacher Dashboard Overview" data-tour-desc="Provides a central summary of classroom analytics, including total enrolled students, average attendance metrics, warning alerts, and course assignments.">
          <span class="nav-icon">⚡</span>Dashboard
        </div>
        <div class="menu-item demo-tour-item" data-sec="t-students" onclick="switchSec('t', 'students')" data-tour-title="All Students Directory" data-tour-desc="A searchable index showing student details, section details, real-time attendance rate statistics, and their global academic standing.">
          <span class="nav-icon">👥</span>All Students
        </div>
        <div class="menu-item demo-tour-item" data-sec="t-attendance" onclick="switchSec('t', 'attendance')" data-tour-title="Face Attendance Marker" data-tour-desc="Allows teachers to schedule lectures, launch live video streams, and run real-time automated AI facial recognition attendance tracking.">
          <span class="nav-icon">🎥</span>Mark Attendance
        </div>
        
        <div class="sidebar-section">Reports</div>
        <div class="menu-item demo-tour-item" data-sec="t-risk" onclick="switchSec('t', 'risk')" data-tour-title="At-Risk Analytics" data-tour-desc="Flagging engine that lists students whose grades or attendance have dropped below threshold, warning teachers to take preventive measures.">
          <span class="nav-icon">⚠️</span>At-Risk Warning
        </div>
        <div class="menu-item demo-tour-item" data-sec="t-engagement" onclick="switchSec('t', 'engagement')" data-tour-title="Gaze/Engagement Report" data-tour-desc="Displays real-time gaze tracking data, focus logs, and graphs indicating active student participation levels in current lectures.">
          <span class="nav-icon">📈</span>Engagement logs
        </div>
      </div>
    </div>

    <!-- Student Sidebar -->
    <div class="sidebar" id="sidebar-student" style="display:none;">
      <div class="sidebar-brand">
        📊 EngageTracker
        <span>Student Workspace</span>
      </div>
      <div class="sidebar-menu">
        <div class="sidebar-section">Main</div>
        <div class="menu-item active demo-tour-item" data-sec="s-dashboard" onclick="switchSec('s', 'dashboard')" data-tour-title="Student Dashboard" data-tour-desc="A user-centric portal summarizing your overall GPA performance, average attendance rates, class participation stats, and pending assignments.">
          <span class="nav-icon">⚡</span>Dashboard
        </div>
        <div class="menu-item demo-tour-item" data-sec="s-attendance" onclick="switchSec('s', 'attendance')" data-tour-title="Attendance Records" data-tour-desc="Shows detailed subject-wise attendance logs, present/absent dates calendar, and warning indicators if your attendance is critically low.">
          <span class="nav-icon">📅</span>My Attendance
        </div>
        <div class="menu-item demo-tour-item" data-sec="s-assignments" onclick="switchSec('s', 'assignments')" data-tour-title="Assignments Workspace" data-tour-desc="Displays all active coursework tasks assigned by teachers, due dates, grading status, and custom file upload forms for submissions.">
          <span class="nav-icon">📂</span>Assignments
        </div>
        
        <div class="sidebar-section">Interactions</div>
        <div class="menu-item demo-tour-item" data-sec="s-engagement" onclick="switchSec('s', 'engagement')" data-tour-title="Live Classroom &amp; Quizzes" data-tour-desc="Allows students to launch current live class streams, participate in interactive web-based quizzes, and check their live engagement charts.">
          <span class="nav-icon">🎮</span>Live Quiz &amp; Class
        </div>
      </div>
    </div>


    <!-- ==================== MAIN CONTENT ==================== -->
    <div class="main-content">
      
      <!-- ============ TEACHER VIEW SECTIONS ============ -->
      <div id="role-teacher-content">
        
        <!-- Teacher Dashboard Overview -->
        <div id="t-sec-dashboard" class="demo-view-section active">
          <div class="stat-grid">
            <div class="stat-card demo-tour-item" data-tour-title="Total Students Card" data-tour-desc="Displays the count of enrolled students. You can hover/click to inspect all sections in the main students index.">
              <div class="stat-icon pu">👥</div>
              <div class="stat-details">
                <h3>42</h3>
                <p>Total Students</p>
              </div>
            </div>
            <div class="stat-card demo-tour-item" data-tour-title="Avg Attendance Tracker" data-tour-desc="Calculates the running attendance percentage across all courses taught by the logged-in teacher.">
              <div class="stat-icon gr">📅</div>
              <div class="stat-details">
                <h3>88.5%</h3>
                <p>Avg Attendance</p>
              </div>
            </div>
            <div class="stat-card demo-tour-item" data-tour-title="At-Risk Alerts Counter" data-tour-desc="Highlights the count of students with attendance under 75% or GPA below 2.0 requiring active follow-up.">
              <div class="stat-icon pi">⚠️</div>
              <div class="stat-details">
                <h3>3</h3>
                <p>At-Risk Students</p>
              </div>
            </div>
            <div class="stat-card demo-tour-item" data-tour-title="Active Assignments" data-tour-desc="Total count of active assignments with submit timelines. Click to review student submissions.">
              <div class="stat-icon bl">📂</div>
              <div class="stat-details">
                <h3>5</h3>
                <p>Active Tasks</p>
              </div>
            </div>
          </div>

          <div class="dashboard-grid">
            <div class="card demo-tour-item" data-tour-title="Class Attendance Trend" data-tour-desc="Interactive line chart tracking class presence records week-over-week. Helps spot drops in active classroom numbers.">
              <div class="card-title">Attendance Overview (Weekly)</div>
              <div style="height: 250px;">
                <canvas id="teacherAttendanceChart"></canvas>
              </div>
            </div>
            <div class="card demo-tour-item" data-tour-title="Recent At-Risk List" data-tour-desc="Real-time warning list identifying students requiring attention. Lets you send immediate notifications directly from the dashboard.">
              <div class="card-title">Recent At-Risk alerts</div>
              <div class="table-container">
                <table>
                  <thead>
                    <tr>
                      <th>Name</th>
                      <th>Att. %</th>
                      <th>Action</th>
                    </tr>
                  </thead>
                  <tbody>
                    <tr>
                      <td>Amit Kumar</td>
                      <td><span class="badge badge-danger">64%</span></td>
                      <td><span style="font-size: 0.75rem; color: var(--primary); cursor: pointer;">⚠️ Send Alert</span></td>
                    </tr>
                    <tr>
                      <td>Priya Sharma</td>
                      <td><span class="badge badge-danger">69%</span></td>
                      <td><span style="font-size: 0.75rem; color: var(--primary); cursor: pointer;">⚠️ Send Alert</span></td>
                    </tr>
                    <tr>
                      <td>Rahul Singh</td>
                      <td><span class="badge badge-warning">73%</span></td>
                      <td><span style="font-size: 0.75rem; color: var(--primary); cursor: pointer;">⚠️ Send Alert</span></td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>

        <!-- Teacher All Students View -->
        <div id="t-sec-students" class="demo-view-section">
          <div class="card demo-tour-item" data-tour-title="Students Directory Grid" data-tour-desc="Lists all student profiles in your classes. Provides instant options to view profile, attendance timeline, or exam transcripts.">
            <div class="card-title">Students Registry (Section A &amp; B)</div>
            <div class="table-container">
              <table>
                <thead>
                  <tr>
                    <th>Student Name</th>
                    <th>Roll Number</th>
                    <th>Attendance</th>
                    <th>Avg Score</th>
                    <th>Status</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <td>
                      <div class="user-profile">
                        <div class="user-avatar" style="background:#5b37b7;">AK</div>
                        <div>Amit Kumar</div>
                      </div>
                    </td>
                    <td>GLA2026/0122</td>
                    <td>64%</td>
