  <!-- Javascript Logic -->
  <script>
    // Variables for Chart Instances
    let tAttChartInstance = null;
    let tEngChartInstance = null;
    let sPerfChartInstance = null;

    // Switch between Student and Teacher dashboards
    function switchRole(role) {
      // Toggle switcher buttons
      document.querySelectorAll('.role-switcher .role-btn').forEach(btn => btn.classList.remove('active'));
      
      // Get the correct button to set active
      const buttons = document.querySelectorAll('.role-switcher .role-btn');
      if (role === 'teacher') {
        buttons[0].classList.add('active');
        document.getElementById('role-teacher-content').style.display = 'block';
        document.getElementById('role-student-content').style.display = 'none';
        document.getElementById('sidebar-teacher').style.display = 'flex';
        document.getElementById('sidebar-student').style.display = 'none';
        switchSec('t', 'dashboard');
      } else {
        buttons[1].classList.add('active');
        document.getElementById('role-teacher-content').style.display = 'none';
        document.getElementById('role-student-content').style.display = 'block';
        document.getElementById('sidebar-teacher').style.display = 'none';
        document.getElementById('sidebar-student').style.display = 'flex';
        switchSec('s', 'dashboard');
      }
    }

    // Switch between sidebar subsections
    function switchSec(prefix, sectionId) {
      // Deactivate all sidebar items for the current active role
      const sidebarContainer = document.getElementById(`sidebar-${prefix === 't' ? 'teacher' : 'student'}`);
      sidebarContainer.querySelectorAll('.menu-item').forEach(item => item.classList.remove('active'));

      // Find selected menu item and make it active
      const selectedMenuItem = Array.from(sidebarContainer.querySelectorAll('.menu-item')).find(item => item.getAttribute('data-sec') === `${prefix}-${sectionId}`);
      if (selectedMenuItem) {
        selectedMenuItem.classList.add('active');
      }

      // Hide all demo view sections under the current role wrapper
      const contentWrapper = document.getElementById(`role-${prefix === 't' ? 'teacher' : 'student'}-content`);
      contentWrapper.querySelectorAll('.demo-view-section').forEach(sec => sec.classList.remove('active'));

      // Show selected section view
      const selectedView = document.getElementById(`${prefix}-sec-${sectionId}`);
      if (selectedView) {
        selectedView.classList.add('active');
      }

      // Re-initialize Charts when view becomes active
      setTimeout(() => {
        initCharts(prefix, sectionId);
      }, 50);
    }

    // Chart.js Mock Initialization Engine
    function initCharts(prefix, sectionId) {
      if (prefix === 't' && sectionId === 'dashboard') {
        const ctx = document.getElementById('teacherAttendanceChart');
        if (ctx) {
          if (tAttChartInstance) tAttChartInstance.destroy();
          tAttChartInstance = new Chart(ctx.getContext('2d'), {
            type: 'line',
            data: {
              labels: ['Week 1', 'Week 2', 'Week 3', 'Week 4', 'Week 5', 'Week 6'],
              datasets: [{
                label: 'Class Attendance Rate (%)',
                data: [84, 87, 85, 91, 89, 92],
                borderColor: '#7c3aed',
                backgroundColor: 'rgba(124, 58, 237, 0.05)',
                borderWidth: 3,
                fill: true,
                tension: 0.3
              }]
            },
            options: {
              responsive: true,
              maintainAspectRatio: false,
              plugins: { legend: { display: false } },
              scales: {
                y: { min: 50, max: 100 }
              }
            }
          });
        }
      } else if (prefix === 't' && sectionId === 'engagement') {
        const ctx = document.getElementById('teacherEngagementChart');
        if (ctx) {
          if (tEngChartInstance) tEngChartInstance.destroy();
          tEngChartInstance = new Chart(ctx.getContext('2d'), {
            type: 'bar',
            data: {
              labels: ['Class Joiners', 'Active Screen Time', 'Gaze focus', 'Response rate'],
              datasets: [{
                data: [95, 78, 65, 88],
                backgroundColor: ['#7c3aed', '#39b8ff', '#05cd99', '#ffce20'],
                borderRadius: 6
              }]
            },
            options: {
              responsive: true,
              maintainAspectRatio: false,
              plugins: { legend: { display: false } },
              scales: {
                y: { min: 0, max: 100 }
              }
            }
          });
        }
      } else if (prefix === 's' && sectionId === 'dashboard') {
        const ctx = document.getElementById('studentPerformanceChart');
        if (ctx) {
          if (sPerfChartInstance) sPerfChartInstance.destroy();
          sPerfChartInstance = new Chart(ctx.getContext('2d'), {
            type: 'radar',
            data: {
              labels: ['Attendance', 'Midterms', 'Assignments', 'Quizzes', 'Class Participation'],
              datasets: [{
                label: 'My Scores',
                data: [92, 85, 90, 80, 95],
                borderColor: '#39b8ff',
                backgroundColor: 'rgba(57, 184, 255, 0.2)',
                borderWidth: 2
              }]
            },
            options: {
              responsive: true,
              maintainAspectRatio: false,
              plugins: { legend: { display: false } }
            }
          });
        }
      }
    }

    // Hover Guided Tour Event listeners
    const tooltip = document.getElementById('demo-tooltip');
    const guideTitle = document.getElementById('guide-item-title');
    const guideDesc = document.getElementById('guide-item-desc');

    document.addEventListener('mouseover', function(e) {
      const target = e.target.closest('.demo-tour-item');
      if (target) {
        const title = target.getAttribute('data-tour-title');
        const desc = target.getAttribute('data-tour-desc');
        
        // Update floating helper details
        guideTitle.textContent = title;
        guideDesc.textContent = desc;

        // Position & show mini floating tooltip bubble
        tooltip.textContent = title;
        const rect = target.getBoundingClientRect();
        
        // Horizontal center alignment
        tooltip.style.left = (rect.left + window.scrollX + rect.width / 2) + 'px';
        tooltip.style.top = (rect.top + window.scrollY - 6) + 'px';
        tooltip.classList.add('visible');
      }
    });

    document.addEventListener('mouseout', function(e) {
      const target = e.target.closest('.demo-tour-item');
      if (target) {
        tooltip.classList.remove('visible');
      }
    });

    // Run charts on initial load
    window.addEventListener('load', () => {
      initCharts('t', 'dashboard');
    });
  </script>
