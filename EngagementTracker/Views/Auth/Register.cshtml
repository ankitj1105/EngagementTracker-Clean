@model EngagementTracker.Models.RegisterViewModel
@{ Layout = null; }
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1"/>
<title>Register — Student Engagement &amp; Participation</title>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@700;800;900&family=Inter:wght@400;500;600&display=swap" rel="stylesheet"/>
<style>
*{margin:0;padding:0;box-sizing:border-box;}
html,body{min-height:100%;font-family:'Inter',sans-serif;background:#000;}
body{display:flex;}
.page{display:flex;width:100vw;min-height:100vh;}
.illus{flex:0 0 58%;position:fixed;top:0;left:0;bottom:0;width:58%;overflow:hidden;background:#000;}
.illus::before{content:'';position:absolute;top:-120px;left:-120px;width:500px;height:500px;background:radial-gradient(circle,rgba(124,58,237,.22) 0%,transparent 70%);z-index:0;pointer-events:none;}
.illus::after{content:'';position:absolute;bottom:-80px;right:-80px;width:360px;height:360px;background:radial-gradient(circle,rgba(79,70,229,.15) 0%,transparent 70%);z-index:0;pointer-events:none;}
.grid-overlay{position:absolute;inset:0;z-index:1;pointer-events:none;background-image:radial-gradient(rgba(255,255,255,.07) 1px,transparent 1px);background-size:28px 28px;}
.illus-text{position:absolute;top:8%;left:0;right:0;text-align:center;z-index:10;padding:0 2rem;}
.illus-text h1{font-family:'Nunito',sans-serif;font-weight:900;font-size:1.65rem;color:#fff;line-height:1.3;}
.illus-text h1 span{color:#8b5cf6;}
.illus-text p{font-size:.78rem;color:rgba(255,255,255,.35);margin-top:.5rem;letter-spacing:.08em;text-transform:uppercase;}
.accent-line{width:48px;height:3px;background:linear-gradient(90deg,#7c3aed,#4f46e5);border-radius:2px;margin:.8rem auto 0;}
.student-wrap{position:absolute;bottom:0;left:0;right:0;z-index:5;}
.student-img{display:block;width:100%;object-fit:cover;object-position:bottom center;height:76%;mix-blend-mode:screen;opacity:.92;}
.ground-line{position:absolute;bottom:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,#7c3aed,#4f46e5,transparent);z-index:6;}
.badge{position:absolute;bottom:24px;left:24px;z-index:10;display:flex;align-items:center;gap:8px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:30px;padding:6px 14px 6px 8px;}
.badge-dot{width:8px;height:8px;border-radius:50%;background:#22c55e;box-shadow:0 0 6px #22c55e;}
.badge span{font-size:.72rem;color:rgba(255,255,255,.5);letter-spacing:.04em;}
.form-panel{flex:0 0 42%;margin-left:58%;background:#0a0a0a;display:flex;align-items:center;justify-content:center;padding:2.5rem 2.4rem;min-height:100vh;border-left:1px solid rgba(255,255,255,.06);}
.form-inner{width:100%;max-width:340px;}
.brand{display:flex;align-items:center;gap:12px;margin-bottom:1.8rem;}
.brand-icon{width:44px;height:44px;background:linear-gradient(135deg,#7c3aed,#4f46e5);border-radius:12px;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 16px rgba(124,58,237,.4);flex-shrink:0;}
.brand-icon svg{width:22px;height:22px;}
.brand-name{font-family:'Nunito',sans-serif;font-weight:800;font-size:.85rem;color:#f0eeff;line-height:1.3;}
.brand-name span{display:block;font-size:.68rem;font-weight:500;color:rgba(139,92,246,.8);}
h2{font-family:'Nunito',sans-serif;font-weight:900;font-size:1.5rem;color:#fff;margin-bottom:.22rem;}
.sub{color:rgba(255,255,255,.3);font-size:.8rem;margin-bottom:1.2rem;}
.prog{display:flex;gap:.35rem;margin-bottom:1.2rem;}
.pd{height:2px;border-radius:2px;background:rgba(255,255,255,.08);flex:1;transition:background .3s;}
.pd.done{background:#7c3aed;}
.pd.active{background:linear-gradient(90deg,#7c3aed,#818cf8);}
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:.75rem;}
.fg{margin-bottom:.75rem;}
label{display:block;font-size:.7rem;font-weight:600;color:rgba(255,255,255,.4);margin-bottom:.35rem;letter-spacing:.07em;text-transform:uppercase;}
input{width:100%;background:#111;border:1px solid rgba(255,255,255,.1);border-radius:10px;padding:.72rem .95rem;color:#fff;font-size:.88rem;font-family:'Inter',sans-serif;outline:none;transition:border-color .2s,box-shadow .2s;}
input:focus{border-color:#7c3aed;background:#0d0d0d;box-shadow:0 0 0 3px rgba(124,58,237,.15);}
input::placeholder{color:rgba(255,255,255,.15);}
.role-row{display:flex;gap:.5rem;}
.rp{flex:1;padding:.58rem .5rem;text-align:center;border:1px solid rgba(255,255,255,.1);border-radius:9px;cursor:pointer;font-size:.8rem;color:rgba(255,255,255,.35);transition:all .2s;background:transparent;user-select:none;}
.rp.active{border-color:#7c3aed;color:#a78bfa;background:rgba(124,58,237,.12);}
.btn{width:100%;padding:.8rem;background:linear-gradient(135deg,#7c3aed,#4f46e5);border:none;border-radius:10px;color:#fff;font-size:.93rem;font-weight:700;font-family:'Nunito',sans-serif;cursor:pointer;margin-top:.4rem;letter-spacing:.02em;transition:opacity .2s,transform .15s;}
.btn:hover{opacity:.9;transform:translateY(-1px);}
.err{color:#f87171;font-size:.78rem;margin-bottom:.75rem;padding:.5rem .82rem;background:rgba(248,113,113,.08);border:1px solid rgba(248,113,113,.2);border-radius:8px;display:none;}
.foot{text-align:center;margin-top:1rem;font-size:.8rem;color:rgba(255,255,255,.25);}
.foot a{color:#8b5cf6;text-decoration:none;font-weight:600;}
.divr{display:flex;align-items:center;gap:.7rem;margin:.7rem 0;font-size:.72rem;color:rgba(255,255,255,.1);}
.divr::before,.divr::after{content:'';flex:1;height:1px;background:rgba(255,255,255,.07);}
</style>
</head>
<body>
<div class="page">
  <div class="illus">
    <div class="grid-overlay"></div>
    <div class="illus-text">
      <h1>Student <span>Engagement</span><br/>&amp; Participation</h1>
      <p>GLA University &nbsp;·&nbsp; Smart Campus</p>
      <div class="accent-line"></div>
    </div>
    <div class="student-wrap">
      <img class="student-img" src="data:image/png;base64," alt="Student"/>
    </div>
    <div class="ground-line"></div>
    <div class="badge"><div class="badge-dot"></div><span>Platform Online</span></div>
  </div>

  <div class="form-panel">
    <div class="form-inner">
      <div class="brand">
        <div class="brand-icon">
          <svg viewBox="0 0 24 24" fill="none">
            <circle cx="9" cy="7" r="4" fill="#fff" opacity=".95"/>
            <path d="M2 20c0-3.866 3.134-7 7-7s7 3.134 7 7" stroke="#fff" stroke-width="2" stroke-linecap="round"/>
            <path d="M16 3.5c1.5.5 2.5 1.9 2.5 3.5s-1 3-2.5 3.5" stroke="#c4b5fd" stroke-width="1.5" stroke-linecap="round"/>
            <path d="M19 21c0-2.761-1.343-5-3-5" stroke="#c4b5fd" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </div>
        <div class="brand-name">Student Engagement<span>&amp; Participation Tracker</span></div>
      </div>

      <h2>Create account ✨</h2>
      <p class="sub">Join your campus engagement platform</p>

      <div class="prog">
        <div class="pd active" id="p0"></div>
        <div class="pd" id="p1"></div>
        <div class="pd" id="p2"></div>
      </div>

      <div id="err-msg" class="err"></div>

      <div class="fg">
        <label>Full Name</label>
        <input id="nm" type="text" placeholder="Ankit Kumar Jha"/>
      </div>
      <div class="fg">
        <label>Email Address</label>
        <input id="em" type="email" placeholder="you@gla.ac.in"/>
      </div>
      <div class="fg">
        <label>Password</label>
        <input id="pw" type="password" placeholder="Min 6 characters"/>
      </div>

      <div class="fg">
        <label>I Am A</label>
        <div class="role-row">
          <div class="rp active" id="btn-student" onclick="setRole('student')">🎓 Student</div>
          <div class="rp"       id="btn-teacher" onclick="setRole('teacher')">👩‍🏫 Teacher</div>
        </div>
        <input type="hidden" id="rl" value="student"/>
      </div>

      <!-- Student fields -->
      <div class="grid2" id="student-fields">
        <div class="fg">
          <label>Section</label>
          <input id="sc" type="text" placeholder="O"/>
        </div>
        <div class="fg">
          <label>Roll No.</label>
          <input id="rn" type="text" placeholder="11"/>
        </div>
        <div class="field-group" id="student-photo-field" style="display:none;">
          <label>Your Photo <span style="color:#a78bfa;font-size:.75rem;">(required for face attendance)</span></label>
          <div id="photo-capture-area" style="margin-top:8px;">
            <video id="reg-webcam" autoplay playsinline style="width:100%;border-radius:12px;display:none;background:#000;max-height:200px;object-fit:cover;"></video>
            <canvas id="reg-canvas" style="display:none;"></canvas>
            <div id="photo-preview" style="display:none;text-align:center;">
              <img id="preview-img" style="width:120px;height:120px;border-radius:50%;object-fit:cover;border:3px solid #7c3aed;"/>
              <p style="font-size:.75rem;color:#4ade80;margin-top:8px;">✅ Photo captured!</p>
            </div>
            <div style="display:flex;gap:8px;margin-top:10px;">
              <button type="button" id="start-camera-btn" onclick="startRegCamera()" style="flex:1;padding:.6rem;background:rgba(124,58,237,.15);border:1px solid rgba(124,58,237,.3);border-radius:9px;color:#a78bfa;font-size:.8rem;cursor:pointer;">📷 Open Camera</button>
              <button type="button" id="capture-btn" onclick="captureRegPhoto()" style="flex:1;padding:.6rem;background:linear-gradient(135deg,#7c3aed,#4f46e5);border:none;border-radius:9px;color:#fff;font-size:.8rem;cursor:pointer;display:none;">✅ Capture Photo</button>
              <button type="button" id="retake-btn" onclick="retakePhoto()" style="flex:1;padding:.6rem;background:rgba(239,68,68,.1);border:1px solid rgba(239,68,68,.2);border-radius:9px;color:#f87171;font-size:.8rem;cursor:pointer;display:none;">🔄 Retake</button>
            </div>
          </div>
          <input type="hidden" id="student-photo-data" name="photoData"/>
        </div>
      </div>

      <!-- Teacher fields (hidden by default) -->
      <div class="grid2" id="teacher-fields" style="display:none">
        <div class="fg">
          <label>Department</label>
          <input id="dept" type="text" placeholder="CSE"/>
        </div>
        <div class="fg">
          <label>Enrollment No.</label>
          <input id="enroll" type="text" placeholder="EMP001"/>
        </div>
      </div>

      <button class="btn" id="regBtn" onclick="doRegister()">Create Account</button>
      <div class="divr">or</div>
      <div class="foot">Already have an account? <a href="/Auth/Login">Sign in</a></div>
    </div>
  </div>
</div>

<script>
// Progress bar
document.getElementById('nm').addEventListener('input', function(){ setStep(0); });
document.getElementById('em').addEventListener('input', function(){ setStep(1); });
document.getElementById('pw').addEventListener('input', function(){ setStep(2); });
function setStep(n){
  for(var i=0;i<3;i++){
    var d=document.getElementById('p'+i);
    d.className='pd'+(i<n?' done':i===n?' active':'');
  }
}

// Role switcher
function setRole(role) {
  document.getElementById('rl').value = role;
  if(role === 'teacher') {
    document.getElementById('btn-teacher').classList.add('active');
    document.getElementById('btn-student').classList.remove('active');
    document.getElementById('student-fields').style.display = 'none';
    document.getElementById('teacher-fields').style.display = '';
  } else {
    document.getElementById('btn-student').classList.add('active');
    document.getElementById('btn-teacher').classList.remove('active');
    document.getElementById('teacher-fields').style.display = 'none';
    document.getElementById('student-fields').style.display = '';
  }
}

// Register 
async function doRegister() {
  var errEl = document.getElementById('err-msg');
  var btn   = document.getElementById('regBtn');
  errEl.style.display = 'none';

  var name  = document.getElementById('nm').value.trim();
  var email = document.getElementById('em').value.trim();
  var pass  = document.getElementById('pw').value;
  var role  = document.getElementById('rl').value;

  var section, rollNo;
  if(role === 'teacher') {
    section = document.getElementById('dept').value.trim();
    rollNo  = document.getElementById('enroll').value.trim();
  } else {
    section = document.getElementById('sc').value.trim();
    rollNo  = document.getElementById('rn').value.trim();
  }

  // Validate
  if(!name)    { showErr('Please enter your full name.');    return; }
  if(!email)   { showErr('Please enter your email.');        return; }
  if(!pass)    { showErr('Please enter a password.');        return; }
  if(pass.length < 6) { showErr('Password must be at least 6 characters.'); return; }
  if(!section) { showErr(role==='teacher'?'Please enter your department.':'Please enter your section.'); return; }
  if(!rollNo)  { showErr(role==='teacher'?'Please enter your enrollment no.':'Please enter your roll no.'); return; }

  btn.textContent = 'Creating...';
  btn.style.opacity = '.6';

  try {
    // Firebase creates user
    var cred = await firebaseCreateUser(email, pass);
    var uid  = cred.user.uid;

    // Save profile to Firestore via server
    const res = await fetch('/Auth/RegisterProfile', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        uid:          user.uid,
        name:         document.getElementById('name').value,
        email:        document.getElementById('email').value,
        role:         currentRole,
        section:      document.getElementById('section')?.value || '',
        rollNo:       document.getElementById('rollNo')?.value || '',
        department:   document.getElementById('department')?.value || '',
        enrollmentNo: document.getElementById('enrollmentNo')?.value || '',
        photoData:    document.getElementById('student-photo-data')?.value || ''
      })
    });

    if(!resp.ok) {
      var d = await resp.json();
      throw new Error(d.error || 'Server error. Try again.');
    }

    btn.textContent = 'Done! Redirecting...';
    setTimeout(function(){ window.location.href = '/Auth/Login'; }, 800);

  } catch(err) {
    showErr(err.message);
    btn.textContent = 'Create Account';
    btn.style.opacity = '1';
  }
}

function showErr(msg) {
  var el = document.getElementById('err-msg');
  el.textContent = msg;
  el.style.display = 'block';
}

// Will be set after Firebase loads
var firebaseCreateUser;
</script>

<script type="module">
import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js";
import { getAuth, createUserWithEmailAndPassword } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-auth.js";

const firebaseConfig = {
  apiKey: "AIzaSyB475JsdcS2PVdF0JekeSs3qJ6-ImqXfYo",
  authDomain: "studentengagementtracker.firebaseapp.com",
  databaseURL: "https://studentengagementtracker-default-rtdb.firebaseio.com",
  projectId: "studentengagementtracker",
  storageBucket: "studentengagementtracker.firebasestorage.app",
  messagingSenderId: "267391217533",
  appId: "1:267391217533:web:0963e6877d2ff60384e614"
};

const app  = initializeApp(firebaseConfig);
const auth = getAuth(app);

// Expose to global scope so doRegister() can call it
window.firebaseCreateUser = function(email, password) {
  return createUserWithEmailAndPassword(auth, email, password);
};
var regStream = null;
var photoData = '';

function startRegCamera(){
  var video = document.getElementById('reg-webcam');
  video.style.display = 'block';
  document.getElementById('start-camera-btn').style.display = 'none';
  document.getElementById('capture-btn').style.display = 'flex';
  navigator.mediaDevices.getUserMedia({video:true}).then(function(stream){
    regStream = stream;
    video.srcObject = stream;
  }).catch(function(){alert('Camera access denied.');});
}

function captureRegPhoto(){
  var video = document.getElementById('reg-webcam');
  var canvas = document.getElementById('reg-canvas');
  canvas.width = 320; canvas.height = 320;
  var ctx = canvas.getContext('2d');
  // Crop to square center
  var size = Math.min(video.videoWidth, video.videoHeight);
  var x = (video.videoWidth - size) / 2;
  var y = (video.videoHeight - size) / 2;
  ctx.drawImage(video, x, y, size, size, 0, 0, 320, 320);
  photoData = canvas.toDataURL('image/jpeg', 0.8);
  document.getElementById('student-photo-data').value = photoData;

  // Stop camera
  if(regStream) regStream.getTracks().forEach(function(t){t.stop();});
  video.style.display = 'none';

  // Show preview
  document.getElementById('preview-img').src = photoData;
  document.getElementById('photo-preview').style.display = 'block';
  document.getElementById('capture-btn').style.display = 'none';
  document.getElementById('retake-btn').style.display = 'flex';
  document.getElementById('start-camera-btn').style.display = 'none';
}

function retakePhoto(){
  photoData = '';
  document.getElementById('student-photo-data').value = '';
  document.getElementById('photo-preview').style.display = 'none';
  document.getElementById('retake-btn').style.display = 'none';
  document.getElementById('start-camera-btn').style.display = 'flex';
}

// Show photo field only for students
var origSetRole = window.setRole;
window.setRole = function(role){
  if(origSetRole) origSetRole(role);
  var photoField = document.getElementById('student-photo-field');
  if(photoField) photoField.style.display = role === 'student' ? 'block' : 'none';
};
</script>
</body>
</html>
